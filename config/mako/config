sort=-time
layer=overlay
anchor=top-right

font=Maple Mono NF CN 10
format=<b>%s</b>\n%b
markup=1
text-alignment=left

background-color=#181c27f5
text-color=#e8eaf2ff
width=340
height=96
outer-margin=10,10,0,0
margin=6
padding=10,12
border-size=1
border-color=#ffffff1f
border-radius=18

icons=1
icon-location=left
max-icon-size=42
icon-border-radius=10
icon-path=/usr/share/icons/breeze-dark:/usr/share/icons/breeze:/usr/share/icons/Adwaita:/usr/share/icons/AdwaitaLegacy:/usr/share/icons/hicolor

max-visible=4
group-by=app-name
default-timeout=6000
ignore-timeout=0
progress-color=over #89b4facc

[urgency=low]
background-color=#181c27ed
text-color=#bac2deff
border-color=#ffffff1f
default-timeout=3500

[urgency=normal]
border-color=#ffffff1f

[urgency=critical]
background-color=#2b1922f2
border-color=#f38ba880
default-timeout=0
