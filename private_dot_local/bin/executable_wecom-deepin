#!/bin/sh

list_empty_wecom_layers() {
    niri msg windows 2>/dev/null | awk '
        function emit() {
            if (id && empty_title && wecom)
                print id, width, height
        }
        /^Window ID [0-9]+:/ {
            emit()
            id = $3
            sub(":", "", id)
            empty_title = wecom = 0
            width = height = 0
            next
        }
        /^[[:space:]]+Title: ""$/ { empty_title = 1; next }
        /^[[:space:]]+App ID: "com\.qq\.weixin\.work\.deepin"$/ { wecom = 1; next }
        /^[[:space:]]+Window size:/ { width = $3; height = $5; next }
        END { emit() }
    '
}

# After login, Deepin Wine exposes a large, titleless Explorer composition
# surface above the real WeCom window. Close that surface once it appears.
(
    attempts=0
    while [ "$attempts" -lt 600 ]; do
        layer_rows=$(list_empty_wecom_layers)
        large_layer=$(printf '%s\n' "$layer_rows" | awk '$2 > 500 || $3 > 500 { print $1; exit }')
        if [ -n "$large_layer" ]; then
            layer_ids=$(printf '%s\n' "$layer_rows" | awk '{ print $1 }')
            for layer_id in $layer_ids; do
                niri msg action close-window --id "$layer_id" >/dev/null 2>&1 || true
            done
            exit 0
        fi
        attempts=$((attempts + 1))
        sleep 1
    done
) &

exec /usr/bin/distrobox-enter -n deepin -- /bin/sh -lc '
    export LIBGL_ALWAYS_SOFTWARE=1
    export MESA_LOADER_DRIVER_OVERRIDE=llvmpipe
    export GALLIUM_DRIVER=llvmpipe
    export XIM=fcitx
    export XMODIFIERS=@im=fcitx
    export GTK_IM_MODULE=fcitx
    export QT_IM_MODULE=fcitx
    exec /opt/apps/com.qq.weixin.work.deepin/files/run.sh -f "$@"
' sh "$@"
