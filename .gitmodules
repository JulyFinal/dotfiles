[submodule "alacritty/catppuccin"]
  path = config/alacritty/catppuccin
  url = https://github.com/catppuccin/alacritty.git

[submodule "tmux/tpm"]
  path = config/tmux/plugins/tpm
  url = https://github.com/tmux-plugins/tpm.git

[submodule "zsh/zsh-autosuggestions"]
  path = home/zsh/zsh-autosuggestions
  url = https://github.com/zsh-users/zsh-autosuggestions.git

[submodule "zsh/fast-syntax-highlighting"]
  path = home/zsh/fast-syntax-highlighting
  url = https://github.com/zdharma-continuum/fast-syntax-highlighting.git

[submodule "zsh/zsh-completions"]
  path = home/zsh/zsh-completions
  url = https://github.com/zsh-users/zsh-completions.git
