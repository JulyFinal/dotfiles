#!/usr/bin/env bash
set -u

repo_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
failures=0
warnings=0

# A long-lived shell may predate newly installed mise tools. Shims keep the
# diagnostic accurate without requiring the user to restart their terminal.
if [[ -d "$HOME/.local/share/mise/shims" ]]; then
    export PATH="$HOME/.local/share/mise/shims:$PATH"
fi

ok() { printf 'OK    %s\n' "$*"; }
warn() { printf 'WARN  %s\n' "$*"; warnings=$((warnings + 1)); }
fail() { printf 'FAIL  %s\n' "$*"; failures=$((failures + 1)); }

for command_name in \
    niri waybar kitty fcitx5 hyprlock vicinae mise chezmoi \
    yazi yq stylua ruff ty lua-language-server shfmt taplo deno rustfmt; do
    if command -v "$command_name" >/dev/null 2>&1; then
        ok "command: $command_name"
    else
        fail "missing command: $command_name"
    fi
done

if command_palette_name=$(yq -r '.[0].name' \
    "$repo_dir/dot_config/zsh/commands/git.yaml" 2>/dev/null) && \
   [[ -n "$command_palette_name" && "$command_palette_name" != null ]]; then
    ok 'command palette YAML parser'
else
    fail 'command palette YAML parser failed'
fi

if timeout 10s yazi --debug >/dev/null 2>&1; then
    ok 'yazi configuration schema'
else
    fail 'yazi configuration schema is invalid'
fi

chrome_flags="$HOME/.config/chrome-flags.conf"
if [[ -x "$HOME/.local/bin/chrome-proxy" ]] && \
   [[ -f "$chrome_flags" ]] && \
   ! grep -Eq '^[[:space:]]*--proxy-(server|pac-url)=' "$chrome_flags"; then
    ok 'Chrome proxy is opt-in through chrome-proxy'
else
    fail 'Chrome still has a global proxy or chrome-proxy is missing'
fi

fcitx_theme_dir="$HOME/.local/share/fcitx5/themes/catppuccin-mocha-mauve"
fcitx_classicui="$HOME/.config/fcitx5/conf/classicui.conf"
if [[ -f "$fcitx_classicui" ]] && \
   grep -Fqx 'Theme=catppuccin-mocha-mauve' "$fcitx_classicui" && \
   [[ -f "$fcitx_theme_dir/theme.conf" && -f "$fcitx_theme_dir/panel.svg" && \
      -f "$fcitx_theme_dir/highlight.svg" ]]; then
    ok 'fcitx5 Catppuccin theme'
else
    fail 'fcitx5 Catppuccin theme is incomplete'
fi

mcp_filesystem="$HOME/.local/share/mise/shims/mcp-server-filesystem"
codex_config="$HOME/.codex/config.toml"
if [[ -x "$mcp_filesystem" ]] && [[ -f "$codex_config" ]] && \
   grep -Fq "command = \"$mcp_filesystem\"" "$codex_config"; then
    mcp_response=$(printf '%s\n' \
        '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-11-25","capabilities":{},"clientInfo":{"name":"dotfiles-doctor","version":"1"}}}' \
        | timeout 10s "$mcp_filesystem" "$HOME" 2>/dev/null || true)
    if grep -Fq '"protocolVersion":"2025-11-25"' <<<"$mcp_response"; then
        ok 'Codex filesystem MCP handshake'
    else
        fail 'Codex filesystem MCP handshake failed'
    fi
else
    fail 'Codex filesystem MCP is not installed through Mise'
fi

mcp_atuin="$HOME/.local/share/mise/shims/atuin"
if [[ -x "$mcp_atuin" ]] && [[ -f "$codex_config" ]] && \
   grep -Fq "command = \"$mcp_atuin\"" "$codex_config"; then
    mcp_response=$(printf '%s\n%s\n' \
        '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-03-26","capabilities":{},"clientInfo":{"name":"dotfiles-doctor","version":"1"}}}' \
        '{"jsonrpc":"2.0","id":2,"method":"tools/list","params":{}}' \
        | timeout 10s "$mcp_atuin" mcp 2>/dev/null || true)
    if grep -Fq '"name":"atuin_history"' <<<"$mcp_response" && \
       grep -Fq '"readOnlyHint":true' <<<"$mcp_response"; then
        ok 'Codex Atuin MCP handshake'
    else
        fail 'Codex Atuin MCP handshake failed'
    fi
else
    fail 'Codex Atuin MCP is not configured'
fi

if niri validate >/dev/null 2>&1; then
    ok 'niri configuration'
else
    fail 'niri configuration is invalid'
fi

nvim_output=''
if nvim_output=$(timeout 30s nvim --headless '+qa' 2>&1) && [[ -z "$nvim_output" ]]; then
    ok 'neovim clean startup'
else
    fail 'neovim startup emitted errors'
fi

if chezmoi --source "$repo_dir" --destination "$HOME" verify >/dev/null 2>&1; then
    ok 'chezmoi destination matches source state'
else
    fail 'chezmoi destination differs from source state'
fi

while IFS= read -r unit; do
    [[ -z "$unit" ]] && continue
    if systemctl is-enabled "$unit" >/dev/null 2>&1; then
        ok "system service: $unit"
    else
        fail "system service disabled: $unit"
    fi
done < "$repo_dir/services/system-common.txt"

profile=$(sed -nE 's/^[[:space:]]*profile[[:space:]]*=[[:space:]]*"([^"]+)".*/\1/p' \
    "${XDG_CONFIG_HOME:-$HOME/.config}/chezmoi/chezmoi.toml" 2>/dev/null | head -n1)
if [[ "$profile" == laptop ]]; then
    while IFS= read -r unit; do
        [[ -z "$unit" ]] && continue
        if systemctl is-enabled "$unit" >/dev/null 2>&1; then
            ok "laptop system service: $unit"
        else
            fail "laptop system service disabled: $unit"
        fi
    done < "$repo_dir/services/system-laptop.txt"
fi

if cmp -s "$repo_dir/rootfs/etc/greetd/config.toml" /etc/greetd/config.toml; then
    ok 'system greetd configuration'
else
    fail 'system greetd configuration differs from the repository'
fi

while IFS= read -r unit; do
    [[ -z "$unit" ]] && continue
    if systemctl --user is-enabled "$unit" >/dev/null 2>&1; then
        ok "user service: $unit"
    else
        fail "user service disabled: $unit"
    fi
done < "$repo_dir/services/user-common.txt"

v2rayn_config=${XDG_DATA_HOME:-$HOME/.local/share}/v2rayN/guiConfigs/guiNConfig.json
if [[ -f "$v2rayn_config" ]] && \
   grep -q '"AutoRun": true' "$v2rayn_config" && \
   grep -q '"AutoHideStartup": true' "$v2rayn_config" && \
   grep -q '"Hide2TrayWhenClose": true' "$v2rayn_config"; then
    ok 'v2rayN background settings'
else
    warn 'v2rayN background settings take effect on the next autostart'
fi

if ss -ltn 2>/dev/null | grep -q ':10808 '; then
    ok 'v2rayN port 10808 is listening'
    if curl --silent --fail --max-time 12 --proxy socks5h://127.0.0.1:10808 \
        https://www.google.com/generate_204 --output /dev/null; then
        ok 'proxy HTTP check'
    else
        warn 'proxy port is open, but the external HTTP check failed'
    fi
else
    warn 'v2rayN port 10808 is not listening'
fi

if git -C "$repo_dir" grep -IlE '(BEGIN [A-Z ]*PRIVATE KEY|Authorization: Bearer|api[_-]?key[=:]|password[=:])' \
    -- ':!archive' ':!doctor' >/dev/null 2>&1; then
    fail 'possible secret found in tracked source state'
else
    ok 'tracked secret scan'
fi

printf '\nResult: %d failure(s), %d warning(s)\n' "$failures" "$warnings"
((failures == 0))
