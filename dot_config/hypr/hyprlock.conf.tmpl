# Quiet glass lock screen for niri.
# The current desktop remains the visual anchor, with no avatar or indicator ring.

$font = Maple Mono NF CN
$text = rgba(239, 243, 250, 0.92)
$muted = rgba(225, 232, 242, 0.64)
$glass = rgba(14, 19, 28, 0.58)
$hairline = rgba(255, 255, 255, 0.18)
$accent = rgba(126, 200, 255, 0.88)
$danger = rgba(255, 123, 136, 0.90)

general {
    hide_cursor = true
    immediate_render = true
}

animations {
    enabled = true
    bezier = settle, 0.16, 1, 0.3, 1
    animation = fadeIn, 1, 4, settle
    animation = fadeOut, 1, 3, settle
    animation = inputFieldDots, 1, 2, settle
}

background {
    monitor =
    path = screenshot
    blur_size = 8
    blur_passes = 4
    noise = 0.010
    contrast = 0.92
    brightness = 0.66
    vibrancy = 0.12
    vibrancy_darkness = 0.10
}

# Large clock, deliberately the only strong visual anchor.
label {
    monitor =
    text = $TIME
    color = $text
    font_size = 82
    font_family = $font
    position = 0, 120
    halign = center
    valign = center
}

label {
    monitor =
    text = cmd[update:60000] date +"%m月%d日  %A"
    color = $muted
    font_size = 17
    font_family = $font
    position = 0, 42
    halign = center
    valign = center
}

input-field {
    monitor =
    size = 320, 52
    outline_thickness = 1
    rounding = 18

    inner_color = $glass
    outer_color = $hairline
    check_color = $accent
    fail_color = $danger
    font_color = $text

    font_family = $font
    placeholder_text = <span foreground="##dfe7f2aa">输入密码解锁</span>
    fail_text = <span foreground="##ff7b88">密码不正确</span>
    check_text = <span foreground="##7ec8ff">正在验证</span>

    fade_on_empty = false
    dots_center = true
    dots_size = 0.20
    dots_spacing = 0.28

    position = 0, -92
    halign = center
    valign = center
}

label {
    monitor =
    text = {{ .chezmoi.username }}  ·  $LAYOUT
    color = rgba(225, 232, 242, 0.46)
    font_size = 12
    font_family = $font
    position = 0, 26
    halign = center
    valign = bottom
}
